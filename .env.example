# HuggingFace Configuration
# Get your token from: https://huggingface.co/settings/tokens
HUGGING_FACE_HUB_TOKEN=your-hf-token-here

# Optional: Use local model mode (download & run in sandbox)
# When set to "true", the model will be downloaded to the sandbox and run locally.
# Requires sufficient sandbox memory and storage.
# HF_LOCAL_MODE=false

# AI Gateway (optional, for EdgeOne AI Gateway integration)
# AI_GATEWAY_API_KEY=your-api-key
# AI_GATEWAY_BASE_URL=your-gateway-url
